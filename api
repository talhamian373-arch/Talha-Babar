class CurrencyConverter extends StatefulWidget {
  const CurrencyConverter({super.key});

  @override
  State<CurrencyConverter> createState() => _CurrencyConverterState();
}

class _CurrencyConverterState extends State<CurrencyConverter> {
  final TextEditingController _latController = TextEditingController();
  final TextEditingController _longController = TextEditingController();
  final TextEditingController _amountController = TextEditingController();

  // API Keys
  final String _openCageKey = "2067eb2e307740b68e10037ed24e247f";
  final String _exchangeRateKey = "78bade26d58d7b39a54accd8";
  final String _geminiKey = "AIzaSyDkoQMAbRPf7l26uPwvbOGxUB_Xb1uorHU";

  String _country = "Detecting...";
  String _currencyCode = "";
  String _result = "";
  bool _isLoading = false;

  Future<void> _getCurrentLocation() async {
    LocationPermission permission = await Geolocator.requestPermission();
    if (permission == LocationPermission.denied) return;
    
    Position position = await Geolocator.getCurrentPosition();
    setState(() {
      _latController.text = position.latitude.toString();
      _longController.text = position.longitude.toString();
    });
  }

  Future<void> _processConversion() async {
    if (_latController.text.isEmpty || _longController.text.isEmpty) return;
    setState(() => _isLoading = true);

    try {
      final geoUrl = Uri.parse('https://api.opencagedata.com/geocode/v1/json?q=${_latController.text}+${_longController.text}&key=$_openCageKey');
      final geoResponse = await http.get(geoUrl);
      final geoData = json.decode(geoResponse.body);

      if (geoData['results'].isNotEmpty) {
        var comp = geoData['results'][0]['components'];
        var ann = geoData['results'][0]['annotations']['currency'];
        
        setState(() {
          _country = comp['country'] ?? "Unknown";
          _currencyCode = ann['iso_code'] ?? "";
        });

        if (_currencyCode.isNotEmpty && _amountController.text.isNotEmpty) {
          final exUrl = Uri.parse('https://v6.exchangerate-api.com/v6/$_exchangeRateKey/pair/USD/$_currencyCode/${_amountController.text}');
          final exResponse = await http.get(exUrl);
          final exData = json.decode(exResponse.body);
          setState(() => _result = "${exData['conversion_result']} $_currencyCode");
        }
      }
    } catch (e) {
      setState(() => _result = "Error: $e");
    } finally {
      setState(() => _isLoading = false);
    }
  }

  void _openChat() {
    showModalBottomSheet(
      context: context,
      isScrollControlled: true,
      backgroundColor: Colors.white,
      shape: const RoundedRectangleBorder(borderRadius: BorderRadius.vertical(top: Radius.circular(25))),
      builder: (context) => GeminiChatWidget(apiKey: _geminiKey, country: _country),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text("Cloud Geo-Finance"), centerTitle: true, elevation: 0),
      floatingActionButton: FloatingActionButton.extended(
        onPressed: _openChat,
        backgroundColor: Colors.indigo,
        icon: const Icon(Icons.auto_awesome, color: Colors.white),
        label: const Text("Ask AI", style: TextStyle(color: Colors.white)),
      ),
      body: Padding(
        padding: const EdgeInsets.all(24.0),
        child: SingleChildScrollView(
          child: Column(
            children: [
              const Icon(Icons.cloud_download_rounded, size: 100, color: Colors.indigo),
              const SizedBox(height: 10),
              const Text("Location-Aware Exchange", style: TextStyle(color: Colors.grey, letterSpacing: 1.2)),
              const SizedBox(height: 30),
              ElevatedButton.icon(
                onPressed: _getCurrentLocation,
                icon: const Icon(Icons.my_location),
                label: const Text("Get My Location"),
                style: ElevatedButton.styleFrom(
                  minimumSize: const Size(double.infinity, 50),
                  backgroundColor: Colors.blue.shade50,
                ),
              ),
              const SizedBox(height: 20),
              Row(
                children: [
                  Expanded(child: TextField(controller: _latController, decoration: const InputDecoration(labelText: "Lat", border: OutlineInputBorder()))),
                  const SizedBox(width: 10),
                  Expanded(child: TextField(controller: _longController, decoration: const InputDecoration(labelText: "Long", border: OutlineInputBorder()))),
                ],
              ),
              const SizedBox(height: 15),
              TextField(
                controller: _amountController, 
                decoration: const InputDecoration(
                  labelText: "USD Amount", 
                  border: OutlineInputBorder(), 
                  prefixIcon: Icon(Icons.attach_money)
                ),
                keyboardType: TextInputType.number,
              ),
              const SizedBox(height: 25),
              ElevatedButton(
                onPressed: _isLoading ? null : _processConversion,
                style: ElevatedButton.styleFrom(
                  minimumSize: const Size(double.infinity, 60), 
                  backgroundColor: Colors.indigo, 
                  foregroundColor: Colors.white,
                  shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
                ),
                child: _isLoading ? const CircularProgressIndicator(color: Colors.white) : const Text("Convert Now", style: TextStyle(fontSize: 16, fontWeight: FontWeight.bold)),
              ),
              const SizedBox(height: 40),
              const Divider(),
              Text("Country: $_country", style: const TextStyle(fontSize: 18)),
              if (_result.isNotEmpty)
                Container(
                  margin: const EdgeInsets.only(top: 15),
                  padding: const EdgeInsets.all(15),
                  decoration: BoxDecoration(color: Colors.green.shade50, borderRadius: BorderRadius.circular(12)),
                  child: Text(_result, style: const TextStyle(fontSize: 28, color: Colors.green, fontWeight: FontWeight.bold)),
                ),
            ],
          ),
        ),
      ),
    );
  }
}

class GeminiChatWidget extends StatefulWidget {
  final String apiKey;
  final String country;
  const GeminiChatWidget({super.key, required this.apiKey, required this.country});

  @override
  State<GeminiChatWidget> createState() => _GeminiChatWidgetState();
}

class _GeminiChatWidgetState extends State<GeminiChatWidget> {
  late GenerativeModel model;
  final TextEditingController _chatController = TextEditingController();
  List<Map<String, String>> messages = [];
  bool _isTyping = false;

  @override
  void initState() {
    super.initState();
    // UPDATED: Using gemini-2.5-flash for 2026 stability
    model = GenerativeModel(model: 'gemini-2.5-flash', apiKey: widget.apiKey);
    messages.add({"role": "AI", "text": "Hello! I see you are in ${widget.country}. Need help with local prices or travel tips?"});
  }

  Future<void> _sendMessage() async {
    final userText = _chatController.text;
    if (userText.isEmpty) return;

    setState(() {
      messages.add({"role": "You", "text": userText});
      _chatController.clear();
      _isTyping = true;
    });

    try {
      final prompt = "Context: The user is in ${widget.country}. Be a professional finance and travel assistant. User Message: $userText";
      final content = [Content.text(prompt)];
      final response = await model.generateContent(content);

      setState(() {
        messages.add({"role": "AI", "text": response.text ?? "I couldn't generate a response."});
        _isTyping = false;
      });
    } catch (e) {
      setState(() {
        messages.add({"role": "AI", "text": "Error: $e"});
        _isTyping = false;
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    return Container(
      padding: EdgeInsets.only(bottom: MediaQuery.of(context).viewInsets.bottom, left: 20, right: 20, top: 20),
      height: MediaQuery.of(context).size.height * 0.75,
      child: Column(
        children: [
          Container(width: 40, height: 5, decoration: BoxDecoration(color: Colors.grey[300], borderRadius: BorderRadius.circular(10))),
          const SizedBox(height: 15),
          const Text("Gemini AI Assistant", style: TextStyle(fontSize: 20, fontWeight: FontWeight.bold, color: Colors.indigo)),
          const Divider(),
          Expanded(
            child: ListView.builder(
              itemCount: messages.length,
              itemBuilder: (context, i) {
                bool isUser = messages[i]['role'] == "You";
                return Align(
                  alignment: isUser ? Alignment.centerRight : Alignment.centerLeft,
                  child: Container(
                    margin: const EdgeInsets.symmetric(vertical: 5),
                    padding: const EdgeInsets.all(12),
                    decoration: BoxDecoration(
                      color: isUser ? Colors.indigo : Colors.grey[100],
                      borderRadius: BorderRadius.circular(15),
                    ),
                    child: Text(
                      messages[i]['text']!,
                      style: TextStyle(color: isUser ? Colors.white : Colors.black87),
                    ),
                  ),
                );
              },
            ),
          ),
          if (_isTyping) const Padding(padding: EdgeInsets.all(8.0), child: Text("AI is thinking...", style: TextStyle(fontStyle: FontStyle.italic, color: Colors.grey))),
          Padding(
            padding: const EdgeInsets.symmetric(vertical: 10),
            child: TextField(
              controller: _chatController,
              decoration: InputDecoration(
                hintText: "Ask about ${widget.country}...",
                filled: true,
                fillColor: Colors.grey[50],
                border: OutlineInputBorder(borderRadius: BorderRadius.circular(30), borderSide: BorderSide.none),
                suffixIcon: IconButton(onPressed: _sendMessage, icon: const Icon(Icons.send, color: Colors.indigo)),
              ),
            ),
          ),
        ],
      ),
    );
  }
}api
